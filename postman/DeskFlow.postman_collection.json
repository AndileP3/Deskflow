{
  "info": {
    "name": "DeskFlow API",
    "description": "Internal IT Service Request Portal - API collection covering auth and ticket endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "employeeToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "ticketId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login as Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) { pm.collectionVariables.set('employeeToken', data.token); }",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"employee@deskflow.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) { pm.collectionVariables.set('adminToken', data.token); }",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@deskflow.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Create Ticket (Employee)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.data && data.data._id) { pm.collectionVariables.set('ticketId', data.data._id); }",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employeeToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Printer not connecting\",\n  \"description\": \"The 3rd floor printer won't connect to WiFi.\",\n  \"priority\": \"Medium\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/tickets", "host": ["{{baseUrl}}"], "path": ["tickets"] }
          }
        },
        {
          "name": "Get My Tickets (Employee)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{employeeToken}}" }],
            "url": { "raw": "{{baseUrl}}/tickets", "host": ["{{baseUrl}}"], "path": ["tickets"] }
          }
        },
        {
          "name": "Get All Tickets (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/tickets", "host": ["{{baseUrl}}"], "path": ["tickets"] }
          }
        },
        {
          "name": "Get Tickets Filtered by Status (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/tickets?status=Open",
              "host": ["{{baseUrl}}"],
              "path": ["tickets"],
              "query": [{ "key": "status", "value": "Open" }]
            }
          }
        },
        {
          "name": "Update Ticket Status (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"In Progress\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tickets/{{ticketId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "{{ticketId}}"]
            }
          }
        },
        {
          "name": "Update Ticket Status - Forbidden (Employee)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employeeToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Resolved\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tickets/{{ticketId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "{{ticketId}}"]
            }
          }
        },
        {
          "name": "Create Ticket - Validation Error",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employeeToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"\",\n  \"description\": \"\",\n  \"priority\": \"Urgent\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/tickets", "host": ["{{baseUrl}}"], "path": ["tickets"] }
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "API Health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    }
  ]
}
